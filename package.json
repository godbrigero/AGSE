    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.191",
    "@electron/asar": "^4.2.0",
    "@types/ws": "^8.18.1",
    "simple-git": "^3.36.0",
    "ws": "^8.21.0"
  }
}
